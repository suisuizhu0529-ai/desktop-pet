{
  "name": "desktop-pet",
  "version": "3.0.0",
  "description": "一个可爱的跨平台桌面宠物应用",
  "homepage": "./",
  "main": "public/main.js",
  "homepage-secondary": "public/main.js",
  "author": "Your Name",
  "license": "MIT",
  "scripts": {
    "react-start": "react-scripts start",
    "react-build": "react-scripts build",
    "react-test": "react-scripts test",
    "react-eject": "react-scripts eject",
    "electron-start": "wait-on http://localhost:3000 && electron .",
    "electron-dev": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && electron . --dev\"",
    "electron-build": "npm run react-build && electron-builder",
    "build": "npm run electron-build",
    "start": "npm run electron-dev"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest",
    "concurrently": "latest",
    "wait-on": "latest"
  },
  "build": {
    "appId": "com.pet.desktop",
    "productName": "桌面宠物",
    "files": [
      "public/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "public/assets"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities",
      "icon": "public/assets/icon.icns"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
